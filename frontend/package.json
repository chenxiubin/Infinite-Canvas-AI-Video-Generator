{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "test:backend": "cd ../backend && python -m unittest discover -s tests -v",
    "test:frontend": "npx playwright test",
    "test:mvp4": "npx playwright test",
    "test:legacy": "npx playwright test -c playwright.legacy.config.ts",
    "test:legacy:report": "npx playwright test -c playwright.legacy.config.ts || true",
    "test:legacy:mvp2": "npx playwright test -c playwright.legacy.config.ts mvp2.spec.ts",
    "test:legacy:mvp3": "npx playwright test -c playwright.legacy.config.ts mvp3_*.spec.ts",
    "test": "npm run test:backend && npm run test:frontend"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@xyflow/react": "^12.11.1",
    "lucide-react": "^1.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
