{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "test:backend": "python -m unittest discover -s ../backend/tests",
    "test:e2e": "npx playwright test --grep \"G1|G2|H1|H2|H3|I1|I2|I3|I4|J1|J3|J4|K1|K2-a\"",
    "test:e2e:mvp3": "npx playwright test --grep \"M3-\"",
    "test": "npm run test:backend && npm run test:e2e"
  },
  "dependencies": {
    "@xyflow/react": "^12.11.1",
    "lucide-react": "^1.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
